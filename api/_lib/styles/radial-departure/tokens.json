{
  "canvas": {
    "width": 1080,
    "height": 1350,
    "aspectRatio": "4:5",
    "padding": 72
  },
  "image": {
    "aspectRatio": "2176:2716",
    "format": "jpeg"
  },
  "typography": {
    "title": {
      "family": "DM Sans",
      "coverWeight": 300,
      "contentWeight": 800,
      "coverSize": 80,
      "contentSize": 64
    },
    "subtitle": {
      "family": "DM Sans",
      "weight": 300,
      "size": 32
    },
    "byline": {
      "family": "DM Sans",
      "weight": 300,
      "size": 24
    }
  },
  "composition": {
    "vanishingPointVertical": "38-45% from top",
    "foregroundZone": "lower 20-25%",
    "textZoneStart": "65%",
    "leftRuleWidth": 3,
    "contentStripWidth": 0.28,
    "cornerAccentSize": 0.22,
    "horizontalRuleWidth": 0.40
  },
  "slideTypes": {
    "cover": {
      "photoPresence": "full_bleed",
      "overlay": "linear-gradient(transparent 0%, transparent 45%, rgba(0,0,0,0.6) 65%, var(--primary-dark) 80%)"
    },
    "content_claim": {
      "photoPresence": "right_strip_28pct",
      "gradientFade": "linear-gradient(to right, var(--flat-color-bg) 0%, transparent 100%)"
    },
    "content_quote": {
      "photoPresence": "corner_accent_22pct",
      "gradientFade": "radial-gradient from top-right corner"
    },
    "content_data": {
      "photoPresence": "none",
      "accentRule": "3px solid var(--text-accent), vertical, 7% from left"
    },
    "content_narrative": {
      "photoPresence": "none",
      "accentRule": "1px solid var(--text-accent), horizontal, 40% width"
    },
    "end_cta": {
      "photoPresence": "full_bleed",
      "overlay": "radial-gradient(rgba(0,0,0,0) center, rgba(0,0,0,0.5) edges)"
    }
  },
  "fallback_palette": {
    "primary_dark": "#050f1a",
    "midtone": "#0a2a4a",
    "burst_highlight": "#88e0ff"
  },
  "rendering": {
    "technique": "zoom_burst_radial_motion_blur",
    "pov": "first_person_immersive",
    "motionDirection": "outward_from_center",
    "style": "cinematic editorial photography, hyper-realistic",
    "lens": "wide-angle 24-28mm",
    "exclusions": ["text", "watermarks", "logos", "people", "readable signage"]
  }
}
