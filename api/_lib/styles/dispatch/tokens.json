{
  "_meta": {
    "style": "dispatch",
    "version": "1.0.0",
    "description": "Visual constants for Dispatch style pack. Canvas adapted to 4:5 (1080x1350) for frontend compatibility.",
    "canvas_note": "Original spec was 1080x1080 (1:1). Adapted to match pipeline standard. Phase 2B may revisit."
  },

  "canvas": {
    "width": 1080,
    "height": 1350,
    "aspectRatio": "4:5",
    "format": "portrait"
  },

  "color": {
    "fixed": {
      "textPrimary": "#FFFFFF",
      "nearBlack": "#080808",
      "pureBlack": "#000000"
    },
    "derived": {
      "description": "All other colors derived at runtime by colorEngine.ts from brandHex + pathway + energy.",
      "fields": ["seed", "toneA", "toneB", "textSecondary", "accentHex"]
    },
    "pathwaySeedRanges": {
      "nameArchaeology": {
        "lightnessMultiplier": [0.28, 0.35],
        "saturationMultiplier": [0.60, 0.70],
        "hueDriftDeg": [-10, 10]
      },
      "experienceCapture": {
        "lightnessAbsolute": [3, 10],
        "saturationAbsolute": [0, 30]
      },
      "productElevation": {
        "lightnessAbsolute": [6, 14],
        "saturationAbsolute": [10, 60]
      },
      "symbolLiteralization": {
        "lightnessMultiplier": [0.30, 0.45],
        "saturationMultiplier": [0.78, 0.90],
        "hueDriftDeg": [-5, 5]
      }
    },
    "toneDerivation": {
      "toneA": {
        "lightnessAddend": [8, 14],
        "saturationMultiplier": [0.85, 0.95],
        "maxLightness": 28
      },
      "toneB": {
        "lightnessAddend": [4, 8],
        "saturationMultiplier": [0.25, 0.40]
      },
      "textSecondary": {
        "lightnessAbsolute": [75, 82],
        "saturationMultiplier": [0.15, 0.25]
      },
      "accent": {
        "saturationAbsolute": [85, 95],
        "lightnessAbsolute": [50, 60]
      }
    }
  },

  "typography": {
    "serif": {
      "family": "Cormorant Garamond",
      "fallback": "Georgia, serif"
    },
    "sans": {
      "family": "DM Sans",
      "fallback": "system-ui, sans-serif"
    }
  },

  "cover": {
    "format": "full-bleed",
    "bottomClearZonePct": 15,
    "pathways": {
      "nameArchaeology": { "backgroundType": "flat-with-texture", "textureOpacity": [0.06, 0.10], "illustrationFrameType": "oval-vignette" },
      "experienceCapture": { "backgroundType": "photographic", "motionBlur": true },
      "productElevation": { "backgroundType": "radial-gradient", "compositionDevice": ["cascade", "single-specimen", "explosion"] },
      "symbolLiteralization": { "backgroundType": "radial-gradient", "vignetteIntensity": "heavy", "subjectDetailLevel": "near-silhouette" }
    }
  },

  "rendering": {
    "format": "JPEG",
    "quality": 0.92,
    "negativePrompt": "text, watermark, logo, signature, frame border, UI elements"
  }
}
