{
  "canvas": {
    "width": 1080,
    "height": 1350,
    "padding_side_pct": 7,
    "safe_zone_px": 75
  },
  "typography": {
    "headline_font": "Lora",
    "headline_weight": 700,
    "headline_size_range": [46, 60],
    "headline_case": "title",
    "headline_align": "left",
    "quote_font": "Lora",
    "quote_weight": 700,
    "quote_size_range": [40, 50],
    "quote_case": "sentence",
    "quote_align": "left",
    "byline_font": "Libre Franklin",
    "byline_weight": 700,
    "byline_size_range": [16, 20],
    "byline_case": "uppercase",
    "byline_tracking": "0.08em"
  },
  "colors": {
    "text_primary": "#1A1A1A",
    "text_inverse": "#FFFFFF",
    "fallback_signature": "#CD5C45"
  },
  "layout": {
    "slide_count_range": [3, 4],
    "cover_illustration_zone_pct": 65,
    "cover_text_zone_pct": 35,
    "quote_negative_space_min_pct": 10
  },
  "illustration": {
    "valid_modes": [
      "ink_gouache",
      "conceptual_photography",
      "object_photography",
      "cinematic_render"
    ]
  }
}
